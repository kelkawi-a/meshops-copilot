# ── Trino ─────────────────────────────────────────────────────────────────────
TRINO_URL=http://localhost:8080
TRINO_USER=meshops
TRINO_PASSWORD=              # leave empty for open clusters
# TRINO_VERIFY_SSL=true      # set false for self-signed TLS certs

# ── Superset ──────────────────────────────────────────────────────────────────
SUPERSET_URL=http://localhost:8088
SUPERSET_USER=admin
SUPERSET_PASSWORD=admin
# SUPERSET_DISCOVERY_ENABLED=true   # set false to skip live API scan and use built-in catalogue
# SUPERSET_DISCOVERY_MAX_CHARTS=500 # cap on charts fetched during discovery

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_URL=http://localhost:3000
GRAFANA_TOKEN=

# ── DataHub ───────────────────────────────────────────────────────────────────
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_TOKEN=

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090

# ── LLM (optional — only needed for AI-assisted report generation) ────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
LLM_PROVIDER=openai          # openai | anthropic | openrouter | none
LLM_MODEL=gpt-4o             # any model string accepted by the chosen provider
                             # openrouter examples: openai/gpt-4o  anthropic/claude-3-5-sonnet

# ── Output ────────────────────────────────────────────────────────────────────
MESHOPS_OUTPUT_DIR=./reports
MESHOPS_LOG_LEVEL=INFO
